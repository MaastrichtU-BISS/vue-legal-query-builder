{
  "name": "legal-docs-fetcher",
  "version": "0.1.0",
  "description": "A Vue component library with form and API client for fetching legal documents",
  "main": "./dist/legal-docs-fetcher.umd.js",
  "module": "./dist/legal-docs-fetcher.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/legal-docs-fetcher.es.js",
      "require": "./dist/legal-docs-fetcher.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vue",
    "vue3",
    "component",
    "legal",
    "documents",
    "form",
    "api-client"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaastrichtU-BISS/legal-docs-fetcher.git"
  },
  "homepage": "https://github.com/MaastrichtU-BISS/legal-docs-fetcher#readme",
  "bugs": {
    "url": "https://github.com/MaastrichtU-BISS/legal-docs-fetcher/issues"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
