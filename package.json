{
  "name": "vue-legal-query-builder",
  "version": "0.2.1",
  "description": "A Vue 3 component for building legal document search queries with hierarchical filtering options",
  "main": "./dist/vue-legal-query-builder.umd.js",
  "module": "./dist/vue-legal-query-builder.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-legal-query-builder.es.js",
      "require": "./dist/vue-legal-query-builder.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vue",
    "vue3",
    "component",
    "legal",
    "documents",
    "query",
    "builder",
    "form",
    "search"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaastrichtU-BISS/vue-legal-query-builder.git"
  },
  "homepage": "https://github.com/MaastrichtU-BISS/vue-legal-query-builder#readme",
  "bugs": {
    "url": "https://github.com/MaastrichtU-BISS/vue-legal-query-builder/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "legal-docs-client": "^0.2.1",
    "lucide-vue-next": "^1.0.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "axios": "^1.13.6",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  }
}
